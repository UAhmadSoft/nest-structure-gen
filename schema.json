{
  "root": "D:/projects/authar-quran-api",
  "paths": {
    "src": "/src",
    "entity_module": "/src/infrastructure/entities/db.ts",
    "repository_module": "/src/infrastructure/repository/repository.module.ts",
    "usecase_module": "/src/usecases/usecase.module.ts",
    "controller_module": "/src/infrastructure/controllers/controller.module.ts"
  },
  "char_primary_key": false,
  "insert_to_modules": true,
  "tables": [
    {
      "name": "PartyGames",
      "create_pagination_route": true,
      "create_relation_get_route": true,
      "properties": {
        "title": {
          "type": "varchar",
          "length": 200,
          "comment": "Game title shown in lobby and browser"
        },
        "description": {
          "type": "text",
          "required": false,
          "comment": "Optional description of the game"
        },
        "type": {
          "type": "enum",
          "enum": ["kahoot", "jeopardy"],
          "dbEnumName": "party_games_type_enum",
          "comment": "kahoot = speed-based Q&A; jeopardy = category board"
        },
        "status": {
          "type": "enum",
          "enum": ["draft", "published", "archived"],
          "default": "draft",
          "dbEnumName": "party_games_status_enum"
        },
        "is_community_made": {
          "type": "boolean",
          "default": false,
          "comment": "True if submitted by a community user, false if admin-created"
        },
        "is_public": {
          "type": "boolean",
          "default": true,
          "comment": "Visible to all users in game browser"
        },
        "cover_image_url": {
          "type": "varchar",
          "length": 500,
          "required": false
        },
        "play_count": {
          "type": "int4",
          "default": 0,
          "comment": "Denormalized total completed session count. Increment via repository.increment()."
        },
        "creator_points_awarded": {
          "type": "boolean",
          "default": false,
          "comment": "Set to true after one-time creator points are written to prevent double-award"
        },
        "tags": {
          "type": "jsonb",
          "required": false,
          "default": "'[]'::jsonb",
          "comment": "Array of string tags e.g. [\"prophets\", \"fiqh\", \"ramadan\"]"
        },
        "meta": {
          "type": "jsonb",
          "required": false,
          "default": "'{}'::jsonb",
          "comment": "Extra config e.g. { \"min_players\": 2, \"max_players\": 20 }"
        }
      },
      "relations": {
        "created_by_id": {
          "type": "ManyToOne",
          "entity": "Users",
          "required": true,
          "onDelete": "RESTRICT",
          "onUpdate": "CASCADE"
        },
        "categories": {
          "type": "OneToMany",
          "entity": "PartyGameCategories",
          "required": false
        },
        "questions": {
          "type": "OneToMany",
          "entity": "PartyGameQuestions",
          "required": false
        },
        "sessions": {
          "type": "OneToMany",
          "entity": "PartyGameSessions",
          "required": false
        },
        "ratings": {
          "type": "OneToMany",
          "entity": "PartyGameRatings",
          "required": false
        }
      },
      "indexes": [
        {
          "columns": ["status", "is_public"],
          "name": "idx_party_games_status_public"
        },
        {
          "columns": ["type"],
          "name": "idx_party_games_type"
        },
        {
          "columns": ["play_count"],
          "name": "idx_party_games_play_count"
        }
      ],
      "constraints": [
        {
          "type": "CHECK",
          "name": "party_games_play_count_positive",
          "expression": "play_count >= 0"
        }
      ]
    },
    {
      "name": "PartyGameCategories",
      "create_pagination_route": false,
      "create_relation_get_route": true,
      "properties": {
        "name": {
          "type": "varchar",
          "length": 100,
          "comment": "Category name shown on Jeopardy board e.g. 'Prophets', 'Fiqh'"
        },
        "order": {
          "type": "int4",
          "default": 0,
          "comment": "Left-to-right column order on the Jeopardy board"
        },
        "color": {
          "type": "varchar",
          "length": 20,
          "required": false,
          "comment": "Optional hex color for category header e.g. '#1a73e8'"
        }
      },
      "relations": {
        "game_id": {
          "type": "ManyToOne",
          "entity": "PartyGames",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        },
        "questions": {
          "type": "OneToMany",
          "entity": "PartyGameQuestions",
          "required": false
        }
      },
      "indexes": [
        {
          "columns": ["game_id", "order"],
          "name": "idx_party_game_categories_game_order"
        }
      ]
    },
    {
      "name": "PartyGameQuestions",
      "create_pagination_route": false,
      "create_relation_get_route": true,
      "properties": {
        "question_text": {
          "type": "text",
          "comment": "The question or clue text shown to players"
        },
        "question_type": {
          "type": "enum",
          "enum": ["multiple_choice", "true_false", "text_input"],
          "default": "multiple_choice",
          "dbEnumName": "party_game_questions_type_enum"
        },
        "time_limit_seconds": {
          "type": "int4",
          "default": 30,
          "comment": "How long players have to answer in seconds"
        },
        "points": {
          "type": "int4",
          "default": 100,
          "comment": "Base points for correct answer. Jeopardy: use 100/200/300/400/500."
        },
        "order": {
          "type": "int4",
          "default": 0,
          "comment": "Sequence order for Kahoot; row order within category for Jeopardy"
        },
        "media_url": {
          "type": "varchar",
          "length": 500,
          "required": false,
          "comment": "Optional image or audio URL to display with the question"
        },
        "explanation": {
          "type": "text",
          "required": false,
          "comment": "Islamic context or explanation shown after answer is revealed"
        }
      },
      "relations": {
        "game_id": {
          "type": "ManyToOne",
          "entity": "PartyGames",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        },
        "category_id": {
          "type": "ManyToOne",
          "entity": "PartyGameCategories",
          "required": false,
          "onDelete": "SET NULL",
          "onUpdate": "CASCADE"
        },
        "answer_options": {
          "type": "OneToMany",
          "entity": "PartyGameAnswerOptions",
          "required": false
        },
        "responses": {
          "type": "OneToMany",
          "entity": "PartyGameResponses",
          "required": false
        }
      },
      "indexes": [
        {
          "columns": ["game_id", "order"],
          "name": "idx_party_game_questions_game_order"
        },
        {
          "columns": ["category_id"],
          "name": "idx_party_game_questions_category"
        }
      ],
      "constraints": [
        {
          "type": "CHECK",
          "name": "party_game_questions_time_positive",
          "expression": "time_limit_seconds > 0"
        },
        {
          "type": "CHECK",
          "name": "party_game_questions_points_positive",
          "expression": "points > 0"
        }
      ]
    },
    {
      "name": "PartyGameAnswerOptions",
      "create_pagination_route": false,
      "create_relation_get_route": false,
      "properties": {
        "text": {
          "type": "varchar",
          "length": 500,
          "comment": "Answer option text. For text_input questions, stores accepted answer variants."
        },
        "is_correct": {
          "type": "boolean",
          "default": false
        },
        "order": {
          "type": "int4",
          "default": 0,
          "comment": "Display order: 0=A, 1=B, 2=C, 3=D"
        }
      },
      "relations": {
        "question_id": {
          "type": "ManyToOne",
          "entity": "PartyGameQuestions",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        }
      },
      "indexes": [
        {
          "columns": ["question_id", "is_correct"],
          "name": "idx_party_game_answer_options_question_correct"
        }
      ]
    },
    {
      "name": "PartyGameSessions",
      "create_pagination_route": true,
      "create_relation_get_route": true,
      "properties": {
        "session_code": {
          "type": "varchar",
          "length": 10,
          "required": false,
          "unique": true,
          "comment": "Kahoot only — 6-char alphanumeric join code e.g. 'K7QP2N'. NULL for Jeopardy sessions. Generated via crypto.randomBytes."
        },
        "deep_link": {
          "type": "varchar",
          "length": 500,
          "required": false,
          "comment": "Kahoot only — e.g. app://party/join/K7QP2N. NULL for Jeopardy. Frontend generates QR from this string."
        },
        "status": {
          "type": "enum",
          "enum": ["waiting", "active", "completed", "cancelled"],
          "default": "waiting",
          "dbEnumName": "party_game_sessions_status_enum"
        },
        "started_at": {
          "type": "timestamptz",
          "required": false
        },
        "ended_at": {
          "type": "timestamptz",
          "required": false
        },
        "current_question_index": {
          "type": "int4",
          "default": 0,
          "comment": "Tracks which question is currently active. Host advances this."
        },
        "max_participants": {
          "type": "int4",
          "required": false,
          "comment": "Kahoot only — optional player cap. NULL for Jeopardy or unlimited Kahoot."
        },
        "settings": {
          "type": "jsonb",
          "required": false,
          "default": "'{}'::jsonb",
          "comment": "Session overrides e.g. { \"allow_guests\": true, \"negative_points\": false, \"show_leaderboard_between_questions\": true }"
        }
      },
      "relations": {
        "game_id": {
          "type": "ManyToOne",
          "entity": "PartyGames",
          "required": true,
          "onDelete": "RESTRICT",
          "onUpdate": "CASCADE"
        },
        "host_id": {
          "type": "ManyToOne",
          "entity": "Users",
          "required": true,
          "onDelete": "RESTRICT",
          "onUpdate": "CASCADE"
        },
        "participants": {
          "type": "OneToMany",
          "entity": "PartyGameParticipants",
          "required": false
        },
        "responses": {
          "type": "OneToMany",
          "entity": "PartyGameResponses",
          "required": false
        }
      },
      "indexes": [
        {
          "columns": ["session_code"],
          "unique": true,
          "name": "idx_party_game_sessions_code_unique"
        },
        {
          "columns": ["status"],
          "name": "idx_party_game_sessions_status"
        },
        {
          "columns": ["host_id", "status"],
          "name": "idx_party_game_sessions_host_status"
        }
      ]
    },
    {
      "name": "PartyGameParticipants",
      "create_pagination_route": false,
      "create_relation_get_route": true,
      "properties": {
        "display_name": {
          "type": "varchar",
          "length": 100,
          "comment": "In-game nickname. Auto-filled from user profile or entered manually for guests."
        },
        "total_score": {
          "type": "int4",
          "default": 0,
          "comment": "Accumulated points in this session"
        },
        "rank": {
          "type": "int4",
          "required": false,
          "comment": "Final rank position. Set at session completion. NULL while game is active."
        },
        "joined_at": {
          "type": "timestamptz",
          "default": "NOW()"
        },
        "is_active": {
          "type": "boolean",
          "default": true,
          "comment": "Set to false if player disconnects or leaves mid-game"
        },
        "correct_answers": {
          "type": "int4",
          "default": 0
        },
        "total_answers": {
          "type": "int4",
          "default": 0
        }
      },
      "relations": {
        "session_id": {
          "type": "ManyToOne",
          "entity": "PartyGameSessions",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        },
        "user_id": {
          "type": "ManyToOne",
          "entity": "Users",
          "required": false,
          "onDelete": "SET NULL",
          "onUpdate": "CASCADE",
          "comment": "Kahoot: set when player joins via device. Jeopardy: always NULL — host adds names manually."
        },
        "responses": {
          "type": "OneToMany",
          "entity": "PartyGameResponses",
          "required": false
        }
      },
      "indexes": [
        {
          "columns": ["session_id", "user_id"],
          "name": "idx_party_game_participants_session_user"
        },
        {
          "columns": ["session_id", "total_score"],
          "name": "idx_party_game_participants_session_score"
        }
      ],
      "constraints": [
        {
          "type": "UNIQUE",
          "name": "party_game_participants_session_user_unique",
          "columns": ["session_id", "user_id"]
        },
        {
          "type": "CHECK",
          "name": "party_game_participants_score_positive",
          "expression": "total_score >= 0"
        }
      ]
    },
    {
      "name": "PartyGameResponses",
      "create_pagination_route": false,
      "create_relation_get_route": false,
      "properties": {
        "answer_option_id_selected": {
          "type": "int4",
          "required": false,
          "comment": "ID of the PartyGameAnswerOption the player selected. NULL for text_input questions."
        },
        "text_response": {
          "type": "varchar",
          "length": 500,
          "required": false,
          "comment": "Free-text answer for text_input questions"
        },
        "is_correct": {
          "type": "boolean",
          "default": false,
          "comment": "Evaluated server-side at answer submission time"
        },
        "points_earned": {
          "type": "int4",
          "default": 0,
          "comment": "Actual points after speed bonus calculation. 0 for wrong answers."
        },
        "response_time_ms": {
          "type": "int4",
          "required": false,
          "comment": "Milliseconds from question reveal to answer submission"
        },
        "answered_at": {
          "type": "timestamptz",
          "default": "NOW()"
        }
      },
      "relations": {
        "session_id": {
          "type": "ManyToOne",
          "entity": "PartyGameSessions",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        },
        "participant_id": {
          "type": "ManyToOne",
          "entity": "PartyGameParticipants",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        },
        "question_id": {
          "type": "ManyToOne",
          "entity": "PartyGameQuestions",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        }
      },
      "indexes": [
        {
          "columns": ["session_id", "question_id"],
          "name": "idx_party_game_responses_session_question"
        },
        {
          "columns": ["participant_id"],
          "name": "idx_party_game_responses_participant"
        }
      ],
      "constraints": [
        {
          "type": "UNIQUE",
          "name": "party_game_responses_participant_question_unique",
          "columns": ["participant_id", "question_id"]
        }
      ]
    },
    {
      "name": "PartyGamePointTransactions",
      "create_pagination_route": true,
      "create_relation_get_route": false,
      "properties": {
        "points": {
          "type": "int4",
          "comment": "Points awarded. Always positive in this system."
        },
        "source_type": {
          "type": "enum",
          "enum": ["game_created", "game_played", "game_won", "game_rated"],
          "dbEnumName": "party_game_point_transactions_source_type_enum",
          "comment": "game_created=50pts, game_played=10pts, game_won=25pts, game_rated=5pts"
        },
        "source_id": {
          "type": "int4",
          "required": false,
          "comment": "Polymorphic: ID of the party_game or party_game_session that triggered this"
        },
        "description": {
          "type": "varchar",
          "length": 255,
          "required": false,
          "comment": "Human-readable e.g. 'Won game: Prophets of Islam'"
        }
      },
      "relations": {
        "user_id": {
          "type": "ManyToOne",
          "entity": "Users",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        }
      },
      "indexes": [
        {
          "columns": ["user_id", "source_type"],
          "name": "idx_party_game_point_transactions_user_source"
        },
        {
          "columns": ["created_on"],
          "name": "idx_party_game_point_transactions_created"
        }
      ],
      "constraints": [
        {
          "type": "CHECK",
          "name": "party_game_point_transactions_points_positive",
          "expression": "points > 0"
        }
      ]
    },
    {
      "name": "PartyGameRatings",
      "create_pagination_route": false,
      "create_relation_get_route": false,
      "properties": {
        "rating": {
          "type": "int4",
          "comment": "1–5 star rating"
        },
        "review": {
          "type": "text",
          "required": false,
          "comment": "Optional written review"
        }
      },
      "relations": {
        "game_id": {
          "type": "ManyToOne",
          "entity": "PartyGames",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        },
        "user_id": {
          "type": "ManyToOne",
          "entity": "Users",
          "required": true,
          "onDelete": "CASCADE",
          "onUpdate": "CASCADE"
        }
      },
      "indexes": [
        {
          "columns": ["game_id", "rating"],
          "name": "idx_party_game_ratings_game_rating"
        }
      ],
      "constraints": [
        {
          "type": "UNIQUE",
          "name": "party_game_ratings_game_user_unique",
          "columns": ["game_id", "user_id"]
        },
        {
          "type": "CHECK",
          "name": "party_game_ratings_rating_range",
          "expression": "rating >= 1 AND rating <= 5"
        }
      ]
    }
  ]
}
